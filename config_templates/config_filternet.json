{
  "manifest": {
    "$BASE_DIR": "${configdir}/..",
    "$OUTPUT_DIR": "$BASE_DIR/filternet",
    "$NETWORK_DIR": "$BASE_DIR/network",
    "$COMPONENT_DIR": "$BASE_DIR/../base_props/filter_components"
  },
  "run": {
    "tstop": 3000.0,
    "overwrite_output_dir": true
  },
  "target_simulator": "LGNModel",
  "inputs": {
    "LGN_spikes": {
      "input_type": "movie",
      "module": "graiting",
      "row_size": 80,
      "col_size": 120,
      "gray_screen_dur": 500.0,
      "theta": 45.0,
      "cpd": 0.04,
      "trial": "trial_TRIALNUM",
      "temporal_f": 2.0,
      "contrast": 0.8,
      "degrees_per_pixel": 1.0,
      "evaluation_options": {
        "downsample": 1,
        "separable": true
      }
    }
  },
  "output": {
    "log_file": "log.txt",
    "output_dir": "$OUTPUT_DIR",
    "spikes_csv": "spikes.csv",
    "spikes_h5": "spikes.h5",
    "overwrite_output_dir": true
  },
  "components": {
    "filter_models_dir": "$COMPONENT_DIR/model_templates"
  },
  "networks": {
    "nodes": [
      {
        "nodes_file": "$NETWORK_DIR/lgn_nodes.h5",
        "node_types_file": "$NETWORK_DIR/lgn_node_types.csv"
      }
    ]
  }
}